// Efficient DV Germline Pipeline Configuration

params {
    // Input/Output
    cram = null
    cram_index = null
    output_dir = "results"
    sample_name = "sample"
}

profiles {
    standard {
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    docker {
        docker.enabled = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    gpu {
        process {
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--gpus all'
            }
        }
    }
    
    singularity_gpu {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--nv'
            }
        }
    }
}
