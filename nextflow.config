// Efficient DV Germline Pipeline Configuration

params {
    // Input/Output
    cram = null
    cram_index = null
    output_dir = "results"
    sample_name = "sample"
    
    // Enable trace and report by default
    trace_enabled = true
    report_enabled = true
    timeline_enabled = true
}

// Process execution settings
process {
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Default resources
    cpus = 1
    memory = '4 GB'
    time = '4h'
    
    // Process-specific settings for better parallelization
    withName: SCATTER_INTERVALS {
        time = '30m'
    }
    
    withName: CONVERT_INTERVALS_TO_BED {
        time = '10m'
    }
    
    withName: MAKE_EXAMPLES {
        time = '2h'
        cache = 'lenient'
    }
    
    withName: CALL_VARIANTS {
        time = '4h'
        maxForks = 1  // GPU-intensive, single instance
    }
    
    withName: POST_PROCESS {
        time = '2h'
        memory = '32 GB'  // Increased to prevent segfaults
        errorStrategy = { task.exitStatus == 139 ? 'retry' : 'terminate' }
        maxRetries = 3
    }
}

// Executor settings
executor {
    queueSize = 50
    submitRateLimit = '10 sec'
}

// Enable Nextflow reports
trace {
    enabled = params.trace_enabled
    file = "${params.output_dir}/trace.txt"
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt'
}

timeline {
    enabled = params.timeline_enabled
    file = "${params.output_dir}/timeline.html"
}

report {
    enabled = params.report_enabled
    file = "${params.output_dir}/report.html"
}

// Docker settings
docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g)'
}

profiles {
    standard {
        process.executor = 'local'
        process.cpus = 2
        process.memory = '8 GB'
    }
    
    docker {
        docker.enabled = true
    }
    
    singularity {
        docker.enabled = false
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${env('HOME')}/.singularity/cache"
    }
    
    // High-performance parallel execution profile
    parallel {
        process.executor = 'local'
        
        process {
            withName: MAKE_EXAMPLES {
                maxForks = 20
                cpus = 4
                memory = '16 GB'
            }
            
            withName: CONVERT_INTERVALS_TO_BED {
                maxForks = 40
            }
        }
    }
    
    // GPU-enabled profile for call_variants
    gpu {
        process {
            withName: CALL_VARIANTS {
                accelerator = 1
                containerOptions = '--gpus all'
                cpus = 8
                memory = '64 GB'
            }
        }
    }
    
    singularity_gpu {
        docker.enabled = false
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            withName: CALL_VARIANTS {
                accelerator = 1
                containerOptions = '--nv'
                cpus = 8
                memory = '64 GB'
            }
        }
    }
    
    // Cloud execution profiles
    aws {
        process.executor = 'awsbatch'
        process.queue = 'your-batch-queue'
        aws.region = 'us-east-1'
        aws.batch.cliPath = '/home/ec2-user/miniconda/bin/aws'
    }
    
    gcp {
        process.executor = 'google-batch'
        google.region = 'us-central1'
        google.project = 'your-project-id'
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'compute'
        process.clusterOptions = '--qos=normal'
    }
}
