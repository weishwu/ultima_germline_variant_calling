// Efficient DV Germline Pipeline Configuration

params {
    // Input/Output
    cram = null
    cram_index = null
    output_dir = "results"
    sample_name = "sample"
}

// Executor configuration for parallelism
executor {
    name = 'local'
    cpus = 20  // Adjust based on your system
    memory = '64 GB'
}

process {
    // Allow multiple MAKE_EXAMPLES tasks to run in parallel
    withName: 'MAKE_EXAMPLES' {
        cpus = 2
        memory = '4 GB'
        maxForks = 10  // Run up to 10 in parallel
    }
}

profiles {
    standard {
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    docker {
        docker.enabled = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
        }
    }
    
    gpu {
        process {
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--gpus all'
            }
        }
    }
    
    singularity_gpu {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            errorStrategy = 'retry'
            maxRetries = 2
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--nv'
            }
        }
    }
}
