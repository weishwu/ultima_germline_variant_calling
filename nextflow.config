// Nextflow config file for Efficient DV Germline Variant Calling Pipeline

manifest {
    name = 'ultima-germline-variant-calling'
    description = 'Efficient DV Germline Variant Calling Pipeline for Ultima Genomics data'
    author = 'Adapted from Ultimagen healthomics-workflows'
    version = '1.0.0'
    mainScript = 'main.nf'
    nextflowVersion = '>=25.04'
}

// Default parameters - can be overridden
params {
    // Output directory
    output_dir = "results"
    
    // Docker/Singularity settings
    enable_containers = true
}

// Process configuration
process {
    // Default error strategy
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Process-specific configurations
    withName: 'SCATTER_INTERVALS' {
        container = 'docker://broadinstitute/gatk:latest'
        cpus = 2
        memory = '4 GB'
    }
    
    withName: 'CONVERT_INTERVALS_TO_BED' {
        container = 'docker://broadinstitute/gatk:latest'
        cpus = 1
        memory = '2 GB'
    }
    
    withName: 'MAKE_EXAMPLES' {
        container = 'docker://ultimagenomics/make_examples:3.2.1'
        cpus = 8
        memory = '32 GB'
    }
    
    withName: 'CALL_VARIANTS' {
        container = 'docker://ultimagenomics/call_variants:3.0.0'
        cpus = 8
        memory = '32 GB'
        // Uncomment and adjust for GPU support
        // accelerator = 1
        // containerOptions = '--gpus all'
    }
    
    withName: 'POST_PROCESS' {
        container = 'docker://ultimagenomics/make_examples:3.2.1'
        cpus = 4
        memory = '16 GB'
    }
}

// Profiles for different execution environments
profiles {
    standard {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    
    awsbatch {
        process.executor = 'awsbatch'
        process.queue = 'your-batch-queue'
        aws.region = 'us-east-1'
        docker.enabled = true
    }
    
    google {
        process.executor = 'google-batch'
        google.project = 'your-project-id'
        google.region = 'us-central1'
        docker.enabled = true
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'your-queue'
    }
    
    gpu {
        process {
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--gpus all'
            }
        }
    }
    
    singularity_gpu {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            withName: 'CALL_VARIANTS' {
                accelerator = 1
                containerOptions = '--nv'
            }
        }
    }
    
    test {
        params.scatter_count = 2
        process.memory = '4 GB'
        process.cpus = 2
    }
}

// Execution reports
timeline {
    enabled = true
    file = "${params.output_dir}/timeline.html"
}

report {
    enabled = true
    file = "${params.output_dir}/report.html"
}

trace {
    enabled = true
    file = "${params.output_dir}/trace.txt"
}

dag {
    enabled = true
    file = "${params.output_dir}/dag.svg"
}
